generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String               @id @default(cuid())
  email              String               @unique
  passwordHash       String
  name               String
  status             UserStatus           @default(active)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  codReconciliations CodSettlement[]      @relation("CodReconciledBy")
  devices            Device[]
  managedInventory   InventoryItem[]      @relation("InventoryManagedBy")
  invoicesCreated    Invoice[]            @relation("InvoiceCreatedBy")
  notifications      Notification[]
  createdOrders      Order[]              @relation("OrderCreatedBy")
  managedOrders      Order[]              @relation("OrderManagedBy")
  orderNotesCreated  OrderNote[]          @relation("OrderNoteCreatedBy")
  orderStatusChanges OrderStatusHistory[] @relation("OrderStatusChangedBy")
  createdProducts    Product[]            @relation("ProductCreatedBy")
  managedProducts    Product[]            @relation("ProductManagedBy")
  products           Product[]            @relation("SellerProducts")
  reviews            ProductReview[]
  refreshTokens      RefreshToken[]
  paymentMethods     SavedPaymentMethod[]
  sessions           Session[]
  ticketsCreated     Ticket[]             @relation("TicketCreatedBy")
  addresses          UserAddress[]
  profile            UserProfile?
  roles              UserRole[]
  createdWithdrawals WithdrawalRequest[]  @relation("WithdrawalCreatedBy")
  managedWithdrawals WithdrawalRequest[]  @relation("WithdrawalManagedBy")
  withdrawals        WithdrawalRequest[]  @relation("SellerWithdrawals")
}

model UserProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  phone     String?  @unique
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OtpChallenge {
  id          String    @id @default(cuid())
  phone       String
  purpose     String    @default("login")
  codeHash    String
  expiresAt   DateTime
  attempts    Int       @default(0)
  maxAttempts Int       @default(5)
  resendCount Int       @default(0)
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([phone, createdAt])
  @@index([phone, consumedAt, expiresAt])
}

model Role {
  id          String           @id @default(cuid())
  key         String           @unique
  name        String
  permissions RolePermission[]
  users       UserRole[]
}

model Permission {
  id    String           @id @default(cuid())
  key   String           @unique
  name  String
  roles RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserRole {
  userId String
  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model Device {
  id         String   @id @default(cuid())
  userId     String
  deviceName String?
  userAgent  String?
  ipAddress  String?
  lastSeenAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  sessionToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordReset {
  id        String    @id @default(cuid())
  email     String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model UserAddress {
  id         String   @id @default(cuid())
  userId     String
  label      String?
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String
  country    String   @default("IN")
  phone      String?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SavedPaymentMethod {
  id          String   @id @default(cuid())
  userId      String
  provider    String
  last4       String?
  brand       String?
  externalRef String
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Tag {
  id        String       @id @default(cuid())
  name      String       @unique
  slug      String       @unique
  createdAt DateTime     @default(now())
  products  ProductTag[]
}

model ProductTag {
  productId String
  tagId     String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
}

model AttributeDef {
  id        String                  @id @default(cuid())
  name      String
  slug      String                  @unique
  createdAt DateTime                @default(now())
  products  ProductAttributeValue[]
}

model ProductAttributeValue {
  id          String       @id @default(cuid())
  productId   String
  attributeId String
  value       String
  attribute   AttributeDef @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  product     Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, attributeId])
}

model ProductReview {
  id         String   @id @default(cuid())
  productId  String
  userId     String?
  guestName  String?
  guestEmail String?
  rating     Int
  title      String?
  body       String?
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id])
}

model ReturnRequest {
  id        String              @id @default(cuid())
  orderId   String
  userId    String?
  reason    String?
  status    String              @default("requested")
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  pickup    ReturnPickup?
  order     Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items     ReturnRequestItem[]
}

model ReturnRequestItem {
  id              String        @id @default(cuid())
  returnRequestId String
  orderItemId     String
  requestedQty    Int
  receivedQty     Int           @default(0)
  reasonCode      String?
  conditionStatus String?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @default(now()) @updatedAt
  orderItem       OrderItem     @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  returnRequest   ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)

  @@unique([returnRequestId, orderItemId])
  @@index([returnRequestId])
}

model ReturnPickup {
  id              String        @id @default(cuid())
  returnRequestId String        @unique
  pickupDate      DateTime
  timeSlot        String?
  carrier         String?
  trackingRef     String?
  status          String        @default("scheduled")
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @default(now()) @updatedAt
  returnRequest   ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)

  @@index([pickupDate, status])
}

model AbandonedCart {
  id         String   @id @default(cuid())
  sessionKey String   @unique
  email      String?
  itemsJson  Json
  total      Decimal? @db.Decimal(10, 2)
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
}

model Promotion {
  id        String    @id @default(cuid())
  kind      String
  name      String
  active    Boolean   @default(true)
  startsAt  DateTime?
  endsAt    DateTime?
  productId String?
  metadata  Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  product   Product?  @relation(fields: [productId], references: [id])
}

model WithdrawalRequest {
  id          String   @id @default(cuid())
  sellerId    String?
  amount      Decimal  @db.Decimal(10, 2)
  status      String   @default("pending")
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  managedById String?
  createdBy   User?    @relation("WithdrawalCreatedBy", fields: [createdById], references: [id])
  managedBy   User?    @relation("WithdrawalManagedBy", fields: [managedById], references: [id])
  seller      User?    @relation("SellerWithdrawals", fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([createdById])
  @@index([managedById])
}

model RefundRecord {
  id        String   @id @default(cuid())
  orderId   String
  amount    Decimal  @db.Decimal(10, 2)
  reason    String?
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Category {
  id        String            @id @default(cuid())
  parentId  String?
  name      String
  slug      String            @unique
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  parent    Category?         @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[]        @relation("CategoryTree")
  products  ProductCategory[]
}

model Brand {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now())
  products  Product[]
}

model Product {
  id                   String                          @id @default(cuid())
  sellerId             String?
  brandId              String?
  name                 String
  slug                 String                          @unique
  description          String?
  status               ProductStatus                   @default(draft)
  sku                  String                          @unique
  price                Decimal                         @db.Decimal(10, 2)
  createdAt            DateTime                        @default(now())
  updatedAt            DateTime                        @updatedAt
  basePrice            Decimal?                        @db.Decimal(10, 2)
  discountPercent      Decimal?                        @db.Decimal(5, 2)
  isActive             Boolean                         @default(true)
  isBestSeller         Boolean                         @default(false)
  isFeatured           Boolean                         @default(false)
  metaDescription      String?
  metaTitle            String?
  salePrice            Decimal?                        @db.Decimal(10, 2)
  shelfLife            String?
  stockStatus          StockStatus                     @default(in_stock)
  taxIncluded          Boolean                         @default(true)
  thumbnail            String?
  totalStock           Int                             @default(0)
  type                 ProductType                     @default(variant)
  spiceLevel           SpiceLevel?
  createdById          String?
  managedById          String?
  temperatureSensitive Boolean                         @default(false)
  analyticsSnapshots   AnalyticsDailyProductSnapshot[]
  bundle               Bundle?                         @relation("BundleProduct")
  bundleItems          BundleItem[]
  inventoryItems       InventoryItem[]
  lotStocks            InventoryStockLot[]
  preparationType      String?
  orderItems           OrderItem[]
  brand                Brand?                          @relation(fields: [brandId], references: [id])
  createdBy            User?                           @relation("ProductCreatedBy", fields: [createdById], references: [id])
  managedBy            User?                           @relation("ProductManagedBy", fields: [managedById], references: [id])
  seller               User?                           @relation("SellerProducts", fields: [sellerId], references: [id])
  attributeValues      ProductAttributeValue[]
  categories           ProductCategory[]
  complianceProfile    ProductComplianceProfile?
  details              ProductDetailSection[]
  features             ProductFeature[]
  images               ProductImage[]
  labels               ProductLabel[]
  reviews              ProductReview[]
  seo                  ProductSeo?
  tags                 ProductTag[]
  variants             ProductVariant[]
  promotions           Promotion[]
  sections             ProductSection[]

  @@index([createdById])
  @@index([managedById])
}

model ProductSection {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId   String   @map("product_id")
  title       String   @db.VarChar(255)
  description String
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([productId], map: "idx_product_sections_product_id")
  @@index([productId, sortOrder], map: "idx_product_sections_product_sort")
  @@map("product_sections")
}

model ProductVariant {
  id              String              @id @default(cuid())
  productId       String
  name            String
  sku             String              @unique
  price           Decimal             @db.Decimal(10, 2)
  stock           Int                 @default(0)
  createdAt       DateTime            @default(now())
  discountPercent Decimal?            @db.Decimal(5, 2)
  isDefault       Boolean             @default(false)
  mrp             Decimal?            @db.Decimal(10, 2)
  updatedAt       DateTime            @updatedAt
  weight          String?
  lotStocks       InventoryStockLot[]
  product         Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  position  Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductFeature {
  id        String  @id @default(cuid())
  productId String
  title     String
  icon      String?
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductLabel {
  id        String  @id @default(cuid())
  productId String
  label     String
  color     String?
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductDetailSection {
  id        String  @id @default(cuid())
  productId String
  title     String
  content   String
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductSeo {
  id           String  @id @default(cuid())
  productId    String  @unique
  metaTitle    String?
  metaDesc     String?
  canonicalUrl String?
  product      Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductCategory {
  productId  String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
}

model InventoryItem {
  id          String   @id @default(cuid())
  productId   String
  warehouse   String?
  available   Int      @default(0)
  reserved    Int      @default(0)
  updatedAt   DateTime @updatedAt
  createdById String?
  managedById String?
  managedBy   User?    @relation("InventoryManagedBy", fields: [managedById], references: [id])
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([managedById])
}

model Order {
  id             String               @id @default(cuid())
  userId         String?
  status         OrderStatus          @default(pending)
  currency       String               @default("INR")
  subtotal       Decimal              @db.Decimal(10, 2)
  shipping       Decimal              @db.Decimal(10, 2)
  total          Decimal              @db.Decimal(10, 2)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  createdById    String?
  managedById    String?
  codSettlement  CodSettlement?
  invoice        Invoice?
  createdBy      User?                @relation("OrderCreatedBy", fields: [createdById], references: [id])
  managedBy      User?                @relation("OrderManagedBy", fields: [managedById], references: [id])
  fulfillment    OrderFulfillment?
  items          OrderItem[]
  notes          OrderNote[]
  statusHistory  OrderStatusHistory[]
  refunds        RefundRecord[]
  returnRequests ReturnRequest[]
  shipments      Shipment[]
  transactions   Transaction[]

  @@index([createdById])
  @@index([managedById])
}

model OrderItem {
  id                 String              @id @default(cuid())
  orderId            String
  productId          String
  quantity           Int
  unitPrice          Decimal             @db.Decimal(10, 2)
  lineTotal          Decimal             @db.Decimal(10, 2)
  order              Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product            Product             @relation(fields: [productId], references: [id])
  returnRequestItems ReturnRequestItem[]
  shipmentItems      ShipmentItem[]
}

model Transaction {
  id         String   @id @default(cuid())
  orderId    String
  gateway    String
  amount     Decimal  @db.Decimal(10, 2)
  status     String
  externalId String?
  createdAt  DateTime @default(now())
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Coupon {
  id                String    @id @default(cuid())
  code              String    @unique
  discountType      String
  discountValue     Decimal   @db.Decimal(10, 2)
  active            Boolean   @default(true)
  startsAt          DateTime?
  endsAt            DateTime?
  createdAt         DateTime  @default(now())
  minOrderAmount    Decimal?  @db.Decimal(10, 2)
  maxDiscountAmount Decimal?  @db.Decimal(10, 2)
  usageLimitTotal   Int?
  usageLimitPerUser Int?
  stackable         Boolean   @default(false)
  firstOrderOnly    Boolean   @default(false)
}

model CmsPage {
  id        String       @id @default(cuid())
  slug      String       @unique
  title     String
  status    String       @default("draft")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  sections  CmsSection[]
}

model CmsSection {
  id          String  @id @default(cuid())
  pageId      String
  sectionType String
  position    Int
  contentJson Json
  page        CmsPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
}

model Ticket {
  id          String       @id @default(cuid())
  createdById String
  subject     String
  status      TicketStatus @default(open)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  createdBy   User         @relation("TicketCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Setting {
  id        String   @id @default(cuid())
  group     String
  key       String
  valueJson Json
  updatedAt DateTime @updatedAt

  @@unique([group, key])
}

model ActivityLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
}

model ProductComplianceProfile {
  id                    String                         @id @default(cuid())
  productId             String                         @unique
  ingredients           String?
  nutritionFacts        Json?
  storageInstructions   String?
  fssaiDetails          String?
  allergenInfo          String?
  ingredientDeclaration String?
  complianceState       String                         @default("draft")
  requiresColdChain     Boolean                        @default(false)
  storageTempMin        Decimal?                       @db.Decimal(5, 2)
  storageTempMax        Decimal?                       @db.Decimal(5, 2)
  createdAt             DateTime                       @default(now())
  updatedAt             DateTime                       @default(now()) @updatedAt
  certificates          ProductComplianceCertificate[]
  product               Product                        @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductComplianceCertificate {
  id                String                   @id @default(cuid())
  profileId         String
  certificateType   String
  issuer            String?
  certificateNumber String?
  validFrom         DateTime?
  validUntil        DateTime?
  documentUrl       String?
  verifiedById      String?
  verifiedAt        DateTime?
  createdAt         DateTime                 @default(now())
  profile           ProductComplianceProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Bundle {
  id          String       @id @default(cuid())
  productId   String?      @unique
  name        String
  slug        String       @unique
  pricingMode String       @default("fixed")
  isCombo     Boolean      @default(true)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @default(now()) @updatedAt
  product     Product?     @relation("BundleProduct", fields: [productId], references: [id])
  items       BundleItem[]
}

model BundleItem {
  id         String  @id @default(cuid())
  bundleId   String
  productId  String
  variantId  String?
  quantity   Int     @default(1)
  isOptional Boolean @default(false)
  minSelect  Int     @default(0)
  maxSelect  Int?
  sortOrder  Int     @default(0)
  bundle     Bundle  @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  product    Product @relation(fields: [productId], references: [id])
}

model Warehouse {
  id           String              @id @default(cuid())
  code         String              @unique
  name         String
  region       String?
  addressLine1 String?
  city         String?
  state        String?
  postalCode   String?
  country      String              @default("IN")
  isActive     Boolean             @default(true)
  priority     Int                 @default(0)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @default(now()) @updatedAt
  lots         InventoryStockLot[]
}

model InventoryStockLot {
  id           String              @id @default(cuid())
  productId    String
  variantId    String?
  warehouseId  String
  batchNo      String
  mfgDate      DateTime?
  expiryDate   DateTime?
  receivedAt   DateTime            @default(now())
  qtyReceived  Int
  qtyAvailable Int
  qtyReserved  Int                 @default(0)
  costPerUnit  Decimal?            @db.Decimal(10, 2)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @default(now()) @updatedAt
  movements    InventoryMovement[]
  product      Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant      ProductVariant?     @relation(fields: [variantId], references: [id])
  warehouse    Warehouse           @relation(fields: [warehouseId], references: [id])

  @@index([productId, warehouseId, expiryDate], map: "InventoryStockLot_product_warehouse_expiry_idx")
}

model InventoryMovement {
  id            String                @id @default(cuid())
  lotId         String
  movementType  InventoryMovementType
  quantity      Int
  referenceType String?
  referenceId   String?
  notes         String?
  occurredAt    DateTime              @default(now())
  lot           InventoryStockLot     @relation(fields: [lotId], references: [id], onDelete: Cascade)
}

model OrderStatusHistory {
  id          String   @id @default(cuid())
  orderId     String
  fromStatus  String?
  toStatus    String
  reasonCode  String?
  notes       String?
  changedById String?
  changedAt   DateTime @default(now())
  changedBy   User?    @relation("OrderStatusChangedBy", fields: [changedById], references: [id])
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, changedAt], map: "OrderStatusHistory_order_changedAt_idx")
}

model OrderFulfillment {
  id                String    @id @default(cuid())
  orderId           String    @unique
  fulfillmentStatus String    @default("pending")
  packedAt          DateTime?
  shippedAt         DateTime?
  deliveredAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @default(now()) @updatedAt
  order             Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Shipment {
  id             String         @id @default(cuid())
  orderId        String
  shipmentNo     String?
  carrier        String?
  trackingNo     String?
  shipmentStatus String         @default("pending")
  shippedAt      DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @default(now()) @updatedAt
  order          Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items          ShipmentItem[]

  @@index([orderId, createdAt])
}

model ShipmentItem {
  id          String    @id @default(cuid())
  shipmentId  String
  orderItemId String
  quantity    Int
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  shipment    Shipment  @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
}

model Invoice {
  id            String   @id @default(cuid())
  orderId       String   @unique
  invoiceNo     String   @unique
  gstin         String?
  taxableAmount Decimal  @db.Decimal(10, 2)
  taxAmount     Decimal  @db.Decimal(10, 2)
  totalAmount   Decimal  @db.Decimal(10, 2)
  generatedAt   DateTime @default(now())
  createdById   String?
  createdBy     User?    @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model OrderNote {
  id          String   @id @default(cuid())
  orderId     String
  note        String
  isInternal  Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())
  createdBy   User?    @relation("OrderNoteCreatedBy", fields: [createdById], references: [id])
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model CodSettlement {
  id              String    @id @default(cuid())
  orderId         String    @unique
  expectedAmount  Decimal   @db.Decimal(10, 2)
  collectedAmount Decimal   @db.Decimal(10, 2)
  settledAmount   Decimal   @db.Decimal(10, 2)
  varianceAmount  Decimal   @default(0) @db.Decimal(10, 2)
  status          String    @default("pending")
  notes           String?
  reconciledById  String?
  reconciledAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reconciledBy    User?     @relation("CodReconciledBy", fields: [reconciledById], references: [id])

  @@index([status, reconciledAt])
}

model AnalyticsDailySalesSnapshot {
  id            String   @id @default(cuid())
  snapshotDate  DateTime
  region        String?
  warehouseId   String?
  currency      String   @default("INR")
  orderCount    Int      @default(0)
  grossSales    Decimal  @db.Decimal(12, 2)
  netSales      Decimal  @db.Decimal(12, 2)
  discountTotal Decimal  @db.Decimal(12, 2)
  refundTotal   Decimal  @db.Decimal(12, 2)
  createdAt     DateTime @default(now())

  @@index([snapshotDate, region], map: "AnalyticsDailySalesSnapshot_date_region_idx")
}

model AnalyticsDailyProductSnapshot {
  id           String   @id @default(cuid())
  snapshotDate DateTime
  productId    String
  variantId    String?
  unitsSold    Int      @default(0)
  revenue      Decimal  @db.Decimal(12, 2)
  returns      Int      @default(0)
  stockOnHand  Int      @default(0)
  createdAt    DateTime @default(now())
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([snapshotDate, productId], map: "AnalyticsDailyProductSnapshot_date_product_idx")
}

model AnalyticsJobRun {
  id            String    @id @default(cuid())
  jobKey        String    @unique
  status        String    @default("idle")
  lastSuccessAt DateTime?
  watermark     String?
  errorMessage  String?
  updatedAt     DateTime  @default(now()) @updatedAt
}

model CustomerSegment {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  ruleJson    Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

model CustomerSegmentMembership {
  segmentId  String
  userId     String
  assignedAt DateTime @default(now())

  @@id([segmentId, userId])
}

model Campaign {
  id          String    @id @default(cuid())
  name        String
  channel     String
  status      String    @default("draft")
  templateRef String?
  scheduledAt DateTime?
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
}

model CampaignExecution {
  id            String    @id @default(cuid())
  campaignId    String
  userId        String?
  status        String    @default("queued")
  providerMsgId String?
  error         String?
  sentAt        DateTime?
  createdAt     DateTime  @default(now())
}

model IntegrationEndpoint {
  id             String   @id @default(cuid())
  name           String
  endpointType   String
  targetUrl      String
  authConfigJson Json?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt
}

model IntegrationOutboxEvent {
  id            String       @id @default(cuid())
  eventType     String
  aggregateType String
  aggregateId   String
  payload       Json
  headers       Json?
  status        OutboxStatus @default(pending)
  availableAt   DateTime     @default(now())
  attemptCount  Int          @default(0)
  lastError     String?
  createdAt     DateTime     @default(now())
  sentAt        DateTime?

  @@index([status, availableAt], map: "IntegrationOutboxEvent_status_available_idx")
}

model IntegrationOutboxAttempt {
  id            String   @id @default(cuid())
  outboxEventId String
  endpointId    String
  attemptNo     Int
  responseCode  Int?
  responseBody  String?
  attemptedAt   DateTime @default(now())
}

model ServiceabilityZone {
  id        String               @id @default(cuid())
  name      String
  region    String?
  isActive  Boolean              @default(true)
  priority  Int                  @default(0)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @default(now()) @updatedAt
  etaRules  DeliveryEtaRule[]
  rules     ServiceabilityRule[]
}

model ServiceabilityRule {
  id            String             @id @default(cuid())
  zoneId        String
  pincodePrefix String?
  pincodeStart  Int?
  pincodeEnd    Int?
  isServiceable Boolean            @default(true)
  codAvailable  Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @default(now()) @updatedAt
  zone          ServiceabilityZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@index([zoneId], map: "ServiceabilityRule_zone_idx")
}

model DeliveryEtaRule {
  id                            String             @id @default(cuid())
  zoneId                        String
  minDays                       Int
  maxDays                       Int
  cutoffHour                    Int?
  temperatureSensitiveExtraDays Int                @default(0)
  createdAt                     DateTime           @default(now())
  updatedAt                     DateTime           @default(now()) @updatedAt
  zone                          ServiceabilityZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
}

enum UserStatus {
  active
  suspended
  deleted
}

enum ProductStatus {
  draft
  published
  archived
}

enum ProductType {
  simple
  variant
}

enum StockStatus {
  in_stock
  out_of_stock
}

enum SpiceLevel {
  mild
  medium
  hot
  extra_hot
}

enum OrderStatus {
  pending
  confirmed
  shipped
  delivered
  cancelled
  packed
  returned
}

enum TicketStatus {
  open
  in_progress
  resolved
  closed
}

enum InventoryMovementType {
  in
  reserve
  release
  pick
  adjust
  writeoff
  transfer
  returned
}

enum OutboxStatus {
  pending
  processing
  sent
  failed
  dead
}
